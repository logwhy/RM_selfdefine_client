[package]
name = "app"
version = "0.1.0"
description = "A Tauri App"
authors = ["you"]
license = ""
repository = ""
edition = "2021"
rust-version = "1.77.2"

[lib]
name = "app_lib"
crate-type = ["staticlib", "cdylib", "rlib"]

[features]
default = []
stub-decoder = []
real-decoder = ["dep:ffmpeg-next", "dep:ffmpeg-sys-next"]

[build-dependencies]
tauri-build = { version = "2.5.6", features = [] }

[dependencies]
serde_json = "1.0"
serde = { version = "1.0", features = ["derive"] }
log = "0.4"
tauri = { version = "2.10.3", features = [] }
tauri-plugin-log = "2"
tokio = { version = "1", features = ["rt-multi-thread", "macros", "sync", "time"] }
rumqttc = "0.24"
ffmpeg-next = { version = "=7.1.0", optional = true }
ffmpeg-sys-next = { version = "=7.1.0", optional = true }

[patch.crates-io]
ffmpeg-sys-next = { path = "vendor/ffmpeg-sys-next-7.1.0" }
